# --- Required ---

# Neon Postgres connection string. Create a free DB at https://console.neon.tech
# Make sure to keep ?sslmode=require — Neon needs it.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Your Siemens PAC2200 meter base URL. NO trailing slash.
METER_BASE_URL=http://82.213.14.12:83

# --- Optional (used in Phase 2 — dashboard / AI / weather) ---

# Coordinates for Qalqiliya (used by Open-Meteo for forecast + radiation)
SITE_LAT=32.190
SITE_LON=34.971
SITE_TIMEZONE=Asia/Hebron

# Electricity tariff in your local currency (NIS / kWh) — used to convert kWh
# into bill estimates in the dashboard. Update if yours is different.
TARIFF_IMPORT_PER_KWH=0.78
TARIFF_EXPORT_PER_KWH=0.40

# OpenRouter API key — only needed for the AI chat / nightly summary
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Default model. Pick a free one to start: meta-llama/llama-3.1-70b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct:free

# --- Poller tuning ---

# How often to poll OVERVIEW (live power) — seconds
POLL_OVERVIEW_SEC=30
# How often to poll INSTANTANEOUS (per-phase V/I/PF) — seconds
POLL_INSTANTANEOUS_SEC=60
# How often to refresh DAILYPROFILE / MONTHLYPROFILE / YEARLYPROFILE
POLL_DAILY_PROFILE_MIN=60
